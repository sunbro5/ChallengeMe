# ─────────────────────────────────────────────────────────────────────────────
#  Zkopíruj do .env a vyplň hodnoty:   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=challengeme
DB_PASS=change_me_strong_password
DB_NAME=challengeme

# ── Admin účet (vytvoří se automaticky při prvním startu) ─────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# ── Doména (použita nginxem a Certbotem pro SSL) ──────────────────────────────
# Lokální vývoj:  DOMAIN=localhost
# Produkce:       DOMAIN=vas-domen.cz
DOMAIN=localhost
